# ═══════════════════════════════════════════════════════════
# LLM Benchmark Pipeline — Configuration Template
# Copy to config.env and edit for your setup
# ═══════════════════════════════════════════════════════════

# ── vLLM Endpoint ──────────────────────────────────────────
VLLM_HOST=localhost
VLLM_PORT=8000
VLLM_API_KEY=dummy
# VLLM_BASE_URL=http://localhost:8000/v1   # uncomment to override

# ── Model ──────────────────────────────────────────────────
# Name as vLLM knows it (check: curl http://localhost:8000/v1/models)
MODEL_NAME=""
# Local path to model weights (for tokenizer access, optional)
MODEL_PATH=""
# Short label for results directory (e.g. "qwen3-35b-abliterated")
MODEL_LABEL=""

# ── Benchmarks to run ──────────────────────────────────────
# Options: lm_eval, bfcl, evalplus, scicode, tau_bench, harmbench
# Use "all" for everything
BENCHMARKS="lm_eval"

# ── lm-eval-harness tasks ──────────────────────────────────
# Default set (reasonable runtime ~30 min)
LM_EVAL_TASKS="mmlu,gsm8k,humaneval,arc_challenge,hellaswag,ifeval,truthfulqa_mc2,winogrande"
# Extended set (longer runtime ~2-3 hours)
# LM_EVAL_TASKS="mmlu,mmlu_pro,gsm8k,humaneval,arc_challenge,hellaswag,ifeval,truthfulqa_mc2,winogrande,bigbench_hard,gpqa"

# ── τ-bench settings ───────────────────────────────────────
TAU_DOMAINS="airline,retail,telecom"
TAU_NUM_TASKS=10

# ── BFCL categories ────────────────────────────────────────
BFCL_CATEGORIES="simple_python,parallel,live_multiple,multi_turn_base"

# ── Comparison model (for abliteration audit) ──────────────
COMPARE_MODEL_NAME=""
COMPARE_MODEL_LABEL=""

# ── Paths (auto-detected, usually no changes needed) ───────
BENCH_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="${BENCH_ROOT}/venv"
RESULTS_DIR="${BENCH_ROOT}/results"
REPOS_DIR="${BENCH_ROOT}/repos"
