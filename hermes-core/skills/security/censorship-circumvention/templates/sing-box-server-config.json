{
  "log": { "level": "warn", "timestamp": true },
  "dns": {
    "servers": [
      { "type": "udp", "tag": "dns-google", "server": "8.8.8.8" },
      { "type": "udp", "tag": "dns-cf", "server": "1.1.1.1" }
    ],
    "strategy": "ipv4_only"
  },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-reality-in",
      "listen": "::",
      "listen_port": 443,
      "users": [
        {
          "name": "main",
          "uuid": "GENERATE-WITH-sing-box-generate-rand-16-hex",
          "flow": "xtls-rprx-vision"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "www.microsoft.com",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "www.microsoft.com",
            "server_port": 443
          },
          "private_key": "GENERATE-WITH-sing-box-generate-reality-keypair",
          "short_id": [
            "GENERATE-WITH-sing-box-generate-rand-8-hex",
            "GENERATE-WITH-sing-box-generate-rand-8-hex",
            "GENERATE-WITH-sing-box-generate-rand-8-hex"
          ],
          "max_time_difference": "5m"
        }
      }
    },
    {
      "type": "hysteria2",
      "tag": "hysteria2-in",
      "listen": "::",
      "listen_port": 9443,
      "up_mbps": 100,
      "down_mbps": 100,
      "users": [
        {
          "name": "main",
          "password": "GENERATE-WITH-openssl-rand-base64-32"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "www.microsoft.com",
        "certificate_path": "/etc/sing-box/certs/hy2-cert.pem",
        "key_path": "/etc/sing-box/certs/hy2-key.pem",
        "alpn": ["h3"],
        "min_version": "1.3"
      },
      "obfs": {
        "type": "salamander",
        "password": "GENERATE-WITH-openssl-rand-base64-16"
      }
    }
  ],
  "outbounds": [
    { "type": "direct", "tag": "direct" }
  ],
  "route": {
    "final": "direct",
    "default_domain_resolver": {
      "server": "dns-google",
      "strategy": "ipv4_only"
    }
  }
}
