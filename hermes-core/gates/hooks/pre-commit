#!/bin/bash
# PRE-COMMIT HOOK — быстрые gate'ы (build + test)
# Блокирует коммит, если build или test не прошли.
# НЕ обходится через --no-verify (блокируется commit-msg hook'ом).
#
# Установка: cp ~/.hermes/gates/hooks/pre-commit .git/hooks/pre-commit
#            chmod +x .git/hooks/pre-commit

GATE_RUNNER="$HOME/.hermes/scripts/quality_gate_runner.py"
PYTHON="$HOME/.hermes/hermes-agent/venv/bin/python3"
WORKDIR="$(git rev-parse --show-toplevel 2>/dev/null || echo '.')"

echo "🔒 Quality Gate (pre-commit): build-gate + test-gate..."

RESULT=$("$PYTHON" "$GATE_RUNNER" \
    --json \
    --mode speed \
    --workdir "$WORKDIR" 2>&1)

EXIT_CODE=$?
VERDICT=$(echo "$RESULT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('verdict','GATE_RUNNER_CRASHED'))" 2>/dev/null)

if [ "$VERDICT" != "ALL_PASSED" ]; then
    echo ""
    echo "🚫 COMMIT BLOCKED: Quality gates failed."
    echo "   Verdict: $VERDICT"
    echo ""

    # Показать детали
    echo "$RESULT" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for g in d.get('gates', []):
    if not g['passed']:
        print(f\"   ❌ {g['gate_name']}: score={g.get('score',0):.0%} threshold={g.get('threshold',0):.0%}\")
        for c in g.get('checks', []):
            if not c['passed']:
                print(f\"      └─ {c['check_id']}: {c.get('actual','')[:80]}\")
                diag = c.get('diagnostic', '')
                if diag:
                    print(f\"         Fix: {diag[:120]}\")
" 2>/dev/null || echo "$RESULT"

    echo ""
    echo "Fix the issues above, then re-commit."
    exit 1
fi

echo "✅ pre-commit gates passed."
exit 0
