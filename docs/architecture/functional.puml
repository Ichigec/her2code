@startuml Hermes_Functional_Data_Flows
' =============================================================================
' Hermes Stack — Functional Architecture (Data Flow Diagram)
' Shows how data flows through the system across major use cases.
' PID: her2code
' Date: 2026-06-19
' =============================================================================

!define FLOW_COLOR #2196F3
!define VOICE_COLOR #4CAF50
!define TOOL_COLOR #FF9800
!define STREAM_COLOR #9C27B0
!define DB_COLOR #607D8B

skinparam backgroundColor #FAFAFA
skinparam defaultFontSize 11
skinparam arrowThickness 1.5

title Hermes Stack — Functional Architecture (Data Flows)\n

' =============================================================================
' LEGEND
' =============================================================================
legend right
  |<#2196F3>   </>| **User → LLM Flow** — Chat/completion pipeline |
  |<#4CAF50>   </>| **Voice Pipeline** — Speech → Text → Speech |
  |<#FF9800>   </>| **MCP Tool Flow** — Agent tool calling |
  |<#9C27B0>   </>| **SSE Streaming** — Real-time events |
  |<#607D8B>   </>| **Persistence** — Storage & retrieval |
endlegend

' =============================================================================
' FLOW 1: User → Android App → Hermes API → LLM Provider → Response
' =============================================================================
rectangle "**Flow 1: Chat Completion Pipeline**" as flow1 #2196F3/10 {

    actor "User\n(Person)" as user_f1

    package "Android App" as android_f1 {
        component "Chat UI\n(Compose)" as chat_ui
        component "ApiClient\n(Retrofit+OkHttp)" as api_client
        component "SseClient\n(SSE Parser)" as sse_client
    }

    package "Hermes API Layer" as api_f1 {
        component "API Server\n(FastAPI :8648)" as api_srv
        component "Gateway\n(Starlette :8643)" as gateway_f1
    }

    package "Hermes Agent Core" as core_f1 {
        component "AIAgent\n(run_agent.py)" as agent_f1
        component "ToolOrch\n(model_tools.py)" as tools_f1
        component "Provider\nAdapter" as prov_f1
    }

    cloud "LLM Providers" as llm_f1 {
        component "OpenAI / Anthropic\nDeepSeek / OpenRouter" as llm_api
    }

    database "Session DB\n(state.db)" as sdb_f1

    ' Flow arrows
    user_f1 -[#2196F3]-> chat_ui : 1. Types message
    chat_ui -[#2196F3]-> api_client : 2. HTTP POST /chat
    api_client -[#2196F3]-> api_srv : 3. JSON request
    api_srv -[#2196F3]-> agent_f1 : 4. agent.process(input)
    agent_f1 -[#2196F3]-> sdb_f1 : 5. Save session
    agent_f1 -[#2196F3]-> tools_f1 : 6. Resolve tools
    tools_f1 -[#2196F3]-> prov_f1 : 7. LLM call
    prov_f1 -[#2196F3]-> llm_api : 8. API request
    llm_api -[#2196F3]-> prov_f1 : 9. Completion
    prov_f1 -[#2196F3]-> agent_f1 : 10. Response
    agent_f1 -[#2196F3]-> sdb_f1 : 11. Save response
    agent_f1 -[#2196F3]-> api_srv : 12. Return
    api_srv -[#2196F3]-> api_client : 13. JSON response
    api_client -[#2196F3]-> chat_ui : 14. Render
    chat_ui -[#2196F3]-> user_f1 : 15. Display
}

' =============================================================================
' FLOW 2: Voice Pipeline — SpeechRecognizer → Hermes → TTS
' =============================================================================
rectangle "**Flow 2: Voice Pipeline**" as flow2 #4CAF50/10 {

    actor "User\n(Speaks)" as user_f2

    package "Voice Infrastructure" as voice_f2 {
        component "Voice Proxy\n(:8647)" as voice_proxy_f2
        component "STT Engine\n(faster-whisper)" as stt_f2
        component "TTS Engine\n(Piper)" as tts_f2
        component "Voice Relay\n(:8089 WS)" as relay_f2
    }

    package "Hermes Core" as core_f2 {
        component "AIAgent" as agent_f2
    }

    package "Android App" as android_f2 {
        component "Voice Recorder" as recorder_f2
        component "Audio Player" as player_f2
    }

    ' Flow arrows
    user_f2 -[#4CAF50]-> recorder_f2 : 1. Speaks
    recorder_f2 -[#4CAF50]-> voice_proxy_f2 : 2. Audio stream (OPUS)
    voice_proxy_f2 -[#4CAF50]-> stt_f2 : 3. Audio → Text
    stt_f2 -[#4CAF50]-> voice_proxy_f2 : 4. Transcribed text
    voice_proxy_f2 -[#4CAF50]-> agent_f2 : 5. Text input
    agent_f2 -[#4CAF50]-> voice_proxy_f2 : 6. Text response
    voice_proxy_f2 -[#4CAF50]-> tts_f2 : 7. Text → Audio
    tts_f2 -[#4CAF50]-> voice_proxy_f2 : 8. Audio (WAV)
    voice_proxy_f2 -[#4CAF50]-> player_f2 : 9. Audio stream
    player_f2 -[#4CAF50]-> user_f2 : 10. Plays audio

    note right of relay_f2
        WebSocket relay for
        real-time bidirectional
        audio streaming
    end note
}

' =============================================================================
' FLOW 3: MCP Tool Calling — Agent → MCP Server → Neo4j/Web
' =============================================================================
rectangle "**Flow 3: MCP Tool Calling**" as flow3 #FF9800/10 {

    component "AIAgent\n(Tool Orchestrator)" as agent_f3

    package "MCP Servers" as mcp_f3 {
        component "claw-graph\n(Node.js MCP)" as cg_f3
        component "searchbox\n(Docker :8024)" as sb_f3
        component "education-graph\n(Python MCP)" as eg_f3
        component "codebase-graph\n(Python MCP)" as cb_f3
    }

    database "Neo4j\n(:7687 Bolt)" as neo4j_f3
    cloud "Web Search\nEngines" as web_f3

    ' Flow arrows
    agent_f3 -[#FF9800]-> cg_f3 : 1. graph_search(query)
    agent_f3 -[#FF9800]-> sb_f3 : 1. web_search(query)
    agent_f3 -[#FF9800]-> eg_f3 : 1. education_search(topic)
    agent_f3 -[#FF9800]-> cb_f3 : 1. codebase_search(symbol)

    cg_f3 -[#FF9800]-> neo4j_f3 : 2. Cypher query
    neo4j_f3 -[#FF9800]-> cg_f3 : 3. Graph results
    cg_f3 -[#FF9800]-> agent_f3 : 4. Tool result

    sb_f3 -[#FF9800]-> web_f3 : 2. Search requests
    web_f3 -[#FF9800]-> sb_f3 : 3. Search results
    sb_f3 -[#FF9800]-> agent_f3 : 4. Aggregated results

    eg_f3 -[#FF9800]-> neo4j_f3 : 2. Graph traversal
    neo4j_f3 -[#FF9800]-> eg_f3 : 3. Knowledge paths
    eg_f3 -[#FF9800]-> agent_f3 : 4. Learning paths

    cb_f3 -[#FF9800]-> neo4j_f3 : 2. Codebase query
    neo4j_f3 -[#FF9800]-> cb_f3 : 3. Code matches
    cb_f3 -[#FF9800]-> agent_f3 : 4. Semantic results

    note right of agent_f3
        MCP (Model Context Protocol)
        over stdio or HTTP transport.
        Agent decides which tool
        to call based on context.
    end note
}

' =============================================================================
' FLOW 4: SSE Streaming — Hermes → Gateway → Client
' =============================================================================
rectangle "**Flow 4: SSE (Server-Sent Events) Streaming**" as flow4 #9C27B0/10 {

    component "AIAgent\n(Event Emitter)" as agent_f4
    component "Gateway\n(SSE Handler)" as gw_f4

    package "Clients" as clients_f4 {
        component "Android\nSseClient" as android_f4
        component "OpenCode\nWeb UI" as web_f4
        component "CLI\n(Interactive)" as cli_f4
        component "TUI\n(React/Ink)" as tui_f4
    }

    ' Flow arrows
    agent_f4 -[#9C27B0]-> gw_f4 : 1. Emit event\n(text_delta, tool_call,\n tool_result, done)
    gw_f4 -[#9C27B0]-> android_f4 : 2. SSE: data: {...}\\n\\n
    gw_f4 -[#9C27B0]-> web_f4 : 2. SSE stream
    gw_f4 -[#9C27B0]-> cli_f4 : 2. Console output
    gw_f4 -[#9C27B0]-> tui_f4 : 2. JSON-RPC events

    note bottom of gw_f4
        SSE events:
        • text_delta — streaming token
        • tool_call — tool invocation
        • tool_result — tool output
        • thinking — reasoning
        • error — error info
        • done — completion
    end note

    agent_f4 -[#9C27B0]-> sdb_f1 : 3. Persist events
}

' =============================================================================
' FLOW 5: Persistence & State Management
' =============================================================================
rectangle "**Flow 5: Data Persistence**" as flow5 #607D8B/10 {

    package "Hermes Core" as core_f5 {
        component "AIAgent" as agent_f5
        component "Session\nManager" as session_f5
        component "Memory\nManager" as memory_f5
        component "Cron\nScheduler" as cron_f5
    }

    database "State DB\n(state.db)" as state_f5
    database "Audit DB\n(audit.db)" as audit_f5
    database "Kanban DB\n(kanban.db)" as kanban_f5
    database "Metrics DB\n(metrics.db)" as metrics_f5
    file "MEMORY.md\n(Persistent Memory)" as mem_f5
    file "USER.md\n(User Preferences)" as user_f5
    file "jobs.json\n(Cron Jobs)" as jobs_f5

    session_f5 -[#607D8B]-> state_f5 : INSERT/UPDATE\nmessages, sessions
    agent_f5 -[#607D8B]-> state_f5 : FTS5 search
    agent_f5 -[#607D8B]-> mem_f5 : Read/write context
    agent_f5 -[#607D8B]-> user_f5 : Read preferences
    agent_f5 -[#607D8B]-> audit_f5 : Tool traces,\naudit summaries
    cron_f5 -[#607D8B]-> jobs_f5 : Load/save jobs
    cron_f5 -[#607D8B]-> kanban_f5 : Task events
    agent_f5 -[#607D8B]-> metrics_f5 : Agent metrics,\ntrends

    note right of state_f5
        535 MB (in production)
        FTS5 full-text search
        WAL mode, 0600 perms
        Tables: sessions, messages,
        memory_consolidations
    end note
}

' =============================================================================
' GLOBAL DEPENDENCIES (between flows)
' =============================================================================
note top of flow1
  All flows share:
  • Hermes Agent Core (AIAgent)
  • Session DB (state.db)
  • Provider Adapters
  • Gateway (for SSE)
end note

@enduml
