# Hermes Stack — Docker Environment
# ====================================
# 1. Копировать: cp .env.example .env
# 2. Заполнить ключи: nano .env
# 3. Запустить: docker compose up -d
# 4. НИКОГДА не коммитить .env в Git!

# === LLM Provider (ОБЯЗАТЕЛЬНО хотя бы один) ===
# OpenRouter (рекомендуется — 200+ моделей)
OPENROUTER_API_KEY=*** ИЛИ DeepSeek
DEEPSEEK_API_KEY=*** ИЛИ OpenAI
OPENAI_API_KEY=*** ИЛИ Anthropic
ANTHROPIC_API_KEY=*** API Server key — сгенерировать: openssl rand -hex 32
API_SERVER_KEY=*** Gateway
GATEWAY_ALLOW_ALL_USERS=true
HERMES_DISABLE_MESSAGING=1
