# Hermes Stack — Docker Environment
# ====================================
# 1. Копировать: cp .env.example .env
# 2. Заполнить ключи: nano .env
# 3. Запустить: docker compose up -d
# 4. НИКОГДА не коммитить .env!

# === LLM Provider (ОБЯЗАТЕЛЬНО хотя бы один) ===
# OpenRouter (рекомендуется — 200+ моделей через один ключ)
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=*** DeepSeek (прямой доступ)
# Получить: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=*** OpenAI
OPENAI_API_KEY=*** Anthropic
ANTHROPIC_API_KEY=*** API Server key — сгенерировать командой:
# openssl rand -hex 32
API_SERVER_KEY=*** Gateway
GATEWAY_ALLOW_ALL_USERS=true
HERMES_DISABLE_MESSAGING=1
