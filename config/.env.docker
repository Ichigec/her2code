# Hermes Stack — Docker Environment
# Скопировать: cp config/.env.docker .env
# Отредактировать: nano .env

# LLM Provider (выбрать один и вписать реальный ключ)
DEEPSEEK_API_KEY=***# или:
# OPENAI_API_KEY=*** API Server (ключ для доступа к Hermes API)
API_SERVER_KEY=*** Neo4j (опционально)
NEO4J_PASSWORD=*** Ports
HERMES_API_PORT=18648
