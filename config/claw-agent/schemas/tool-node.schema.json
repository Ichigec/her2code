{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencode-plus.local/schemas/tool-node.schema.json",
  "title": "ToolNode",
  "description": "Canonical tool record for Neo4j projection and enriched tool-catalog entries.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "tool_dir", "name", "description", "type", "target", "mcp_usage"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]+$"
    },
    "tool_dir": {
      "type": "string",
      "description": "Directory of executable, MCP root, or compose service context"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "mcp",
        "lsp",
        "script",
        "compose-service",
        "skill",
        "agent",
        "adapter",
        "llm-model",
        "env",
        "doc"
      ]
    },
    "target": {
      "type": "string",
      "description": "filesystem | web | llm | agents | host | database | …"
    },
    "mcp_usage": {
      "type": "string",
      "description": "JSON string: MCP tool definitions with inputSchema"
    },
    "endpoint": { "type": "string" },
    "c_layer": {
      "type": "string",
      "enum": ["C0", "C1", "C2", "C3", "C4"]
    },
    "linux_layer": {
      "type": "string",
      "enum": [
        "L0", "L1", "L2", "L3", "L4", "L5",
        "L6", "L7", "L8", "L9", "L10", "L11", "L12"
      ]
    },
    "confirmations": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "pruned", "unknown"],
      "default": "active"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[^:\\s][^\\s]*:\\d+(-\\d+)?$"
      }
    },
    "_reserved": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "version": { "type": ["string", "null"] },
        "owner": { "type": ["string", "null"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "cost_tier": { "type": ["string", "null"] },
        "health_status": { "type": ["string", "null"] },
        "last_probe_at": { "type": ["string", "null"] }
      }
    }
  }
}
