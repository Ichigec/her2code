@startuml claw-compactor-data-flow
title Claw / Composter — data flow with claw-compactor plugin
skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultFontName "JetBrains Mono"
skinparam ArrowColor #444
skinparam rectangle {
  BackgroundColor<<src>>       #EAF4FF
  BackgroundColor<<agent>>     #FFE9E0
  BackgroundColor<<plugin>>    #F1E1FF
  BackgroundColor<<store>>     #FFF7CC
  BackgroundColor<<store_new>> #FFE2CC
  BackgroundColor<<external>>  #F5F5F5
}

actor "Operator" as Op

rectangle "Sources of truth" <<src>> {
  component "compose.*.yml" as Compose
  component "opencode MCP\nconfig" as MCPConf
  component ".ai/skills/**" as Skills
  component ".env* / profiles/" as Envs
  component "scripts (start-*.sh)" as Scripts
}

rectangle "Agents" <<agent>> {
  component "claw\n(stateless writer)" as Claw
  component "composter\n(stateful reader)" as Composter
}

rectangle "claw-compactor plugin (§12)" <<plugin>> {
  component "tool.execute.after\nbuffer (per session)" as Buf
  component "experimental.\nsession.compacting\nhook" as Hook
  component "second LLM call\n(structured extract)" as ExtractLLM
  component "mergeAppend()\n(append-only)" as Merge
}

rectangle "Existing storage" <<store>> {
  component "log.jsonl\n(append-only journal)" as Log
  component "summaries/\nYYYY-MM-DD.md" as Summaries
  component "drafts/<op-id>/" as Drafts
  component "registry/\nintegrations.<ts>.json" as Registry
}

rectangle "New storage (§12)" <<store_new>> {
  component "sessions/<sid>/\ncheckpoint.<n>.json\nplan.json\nworkspace.jsonl" as Sessions
  component "knowledge/\ntool-catalog.json\nprospect-index.json\na2a-acp-index.json" as Knowledge
}

component "LiteLLM\n(extractor model)" <<external>> as LiteLLM

Op --> Claw : "/agents claw"
Op --> Composter : "/agents composter"

Compose --> Claw : scan
MCPConf --> Claw : scan
Skills  --> Claw : scan
Envs    --> Claw : scan
Scripts --> Claw : scan

Claw --> Log : append
Claw --> Summaries : append
Claw --> Drafts : write
Claw --> Registry : snapshot

Claw -[#888]-> Buf : "tool.execute.after\n(every tool call)"
Buf --> Hook : aggregate on compaction
Hook --> ExtractLLM : tool trace + prompt
ExtractLLM --> LiteLLM : POST /chat/completions\n(response_format: json_object)
LiteLLM --> ExtractLLM : structured JSON payload
ExtractLLM --> Sessions : write checkpoint.<n>.json + plan.json
ExtractLLM --> Merge : tools_found / prospects / a2a_acp
Merge --> Knowledge : append-only

Hook -[#5566AA]-> Claw : "output.prompt :=\ncontinuation prompt with\nsessions/<sid>/plan.json pointer"

Claw ..> Sessions : "read OWN session\n(seed and resume)"
Claw ..> Knowledge : "read (seed discovery)"

Log --> Composter : read
Summaries --> Composter : read
Drafts --> Composter : read
Registry --> Composter : read
Sessions --> Composter : read (any sid)
Knowledge --> Composter : read

note bottom of Buf
  buffer kept in plugin memory (per sessionID);
  cleared after each checkpoint write
end note

note left of Knowledge
  HARD: append-only.
  New entries push;
  existing id -> last_seen_session,
  confirmations++, evidence := union.
end note

@enduml
