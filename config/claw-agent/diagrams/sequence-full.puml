@startuml claw-compactor-sequence-full
title Claw + Composter — full multi-session lifecycle (with checkpoint plugin)
skinparam shadowing false
skinparam defaultFontName "JetBrains Mono"
skinparam sequenceArrowColor #444

actor User
participant "claw\nsession A" as A
participant "claw-compactor\nplugin" as Plugin
participant "claw\nsession B" as B
participant "composter\nsession C" as C
database ".compactor/" as D

== Session A — first compact ==
User -> A : "/agents claw\ncompact"
A -> D : read knowledge/* (empty / sparse)
A -> A : discover -> classify -> detect -> draft -> log
A -> D : append log.jsonl, summaries/YYYY-MM-DD.md, registry/<ts>.json

== Session A.5 — mid-session checkpoint ==
note over A, Plugin
  input grew past 100k tokens
  -> opencode fires compacting hook
end note
A -> Plugin : experimental.session.compacting
Plugin -> Plugin : extract structured payload
Plugin -> D : sessions/A/checkpoint.1.json + plan.json
Plugin -> D : mergeAppend knowledge/*.json  (first records)
Plugin -> A : output.prompt := continuation prompt
A -> A : continue with continuation summary
A -> User : print summaries/YYYY-MM-DD.md, exit

== Session B — resume on a different day ==
User -> B : "/agents claw\ncompact"
B -> D : read sessions/B/plan.json -> NOT FOUND (cold start ok)
B -> D : read knowledge/*.json (seed: A's confirmed tools)
B -> B : discover (skips already-confirmed tools, focuses on prospects)
B -> B : classify -> detect -> draft -> log
B -> D : append log.jsonl, summaries/, registry/

== Session B.5 — second compact, append-only ==
B -> Plugin : experimental.session.compacting
Plugin -> Plugin : extract payload
Plugin -> D : sessions/B/checkpoint.1.json + plan.json
Plugin -> D : mergeAppend knowledge/*.json
note right of D
  records seen in session A:
    last_seen_session := "B"
    confirmations++
  new records pushed.
  existing facts not overwritten.
end note
Plugin -> B : output.prompt := continuation prompt
B -> User : print summaries/, exit

== Session C — composter explains across A and B ==
User -> C : "/agents composter\nexplain --since 7d"
C -> D : read knowledge/tool-catalog.json (cross-session)
C -> D : read log.jsonl, summaries/
C -> User : "Over 7 days: A discovered N tools, B confirmed M of them and \nadded K new prospects (cite knowledge/tool-catalog.json:line)."
note right of C
  composter does NOT read
  sessions/<A>/ or sessions/<B>/ —
  the cross-session view lives
  in knowledge/.
end note

@enduml
