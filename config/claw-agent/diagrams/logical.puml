@startuml claw-compactor-logical
title Claw / Composter — logical layers (L1..L6)
skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultFontName "JetBrains Mono"
skinparam ArrowColor #444
skinparam rectangle {
  BackgroundColor<<L1>> #EAF4FF
  BackgroundColor<<L2>> #FFF7CC
  BackgroundColor<<L3>> #FFE9E0
  BackgroundColor<<L4>> #E0F5FF
  BackgroundColor<<L4_5>> #F1E1FF
  BackgroundColor<<L5>> #FFE2CC
  BackgroundColor<<L6>> #F0F0F0
}

actor "Human operator" as Op

rectangle "L1 — Entrypoint" <<L1>> {
  component "/agents claw\n/agents composter" as Entry
}

rectangle "L2 — Agent definitions" <<L2>> {
  component ".opencode/agent/claw.md\n(stateless writer)" as ClawAgent
  component ".opencode/agent/composter.md\n(stateful reader)" as ComposterAgent
  note bottom of ClawAgent
    permission.read deny:
      log.jsonl, summaries/**
    permission.read allow (own session):
      sessions/<own_sid>/**, knowledge/**
  end note
}

rectangle "L3 — Runbook" <<L3>> {
  component "opencode_claw/AGENTS.md\n§1..§12" as Runbook
  component "PLAN.md / opinion1.md" as Plans
}

rectangle "L4 — Pipeline & scanners" <<L4>> {
  component "discover -> classify ->\ndetect -> draft -> log -> exit" as Pipeline
  component "9 scanners\n(compose, mcp, skills,\nenv, scripts, arch,\nhealth, litellm, process)" as Scanners
}

rectangle "L4.5 — Plugin layer (NEW, §12)" <<L4_5>> {
  component "opencode+/plugins/claw-compactor\n(experimental.session.compacting hook)" as Plugin
  note bottom of Plugin
    fires when opencode auto-compacts
    a claw / composter session
    (compaction.reserved = 162144)
  end note
}

rectangle "L5 — Schemas" <<L5>> {
  component "compaction-action.schema.json" as S1
  component "integration-record.schema.json" as S2
  component "checkpoint.schema.json\ncontinuation-plan.schema.json\ntool-catalog.schema.json\nprospect-index.schema.json\na2a-acp-index.schema.json" as Snew
}

rectangle "L6 — Storage (.compactor/)" <<L6>> {
  component "log.jsonl\nsummaries/\ndrafts/\nregistry/" as Existing
  component "sessions/<sid>/\n  checkpoint.<n>.json\n  plan.json\n  workspace.jsonl" as Sessions
  component "knowledge/\n  tool-catalog.json\n  prospect-index.json\n  a2a-acp-index.json" as Knowledge
}

Op --> Entry
Entry --> ClawAgent
Entry --> ComposterAgent
ClawAgent --> Runbook
ComposterAgent --> Runbook
Runbook --> Pipeline
Pipeline --> Scanners
Pipeline --> Existing
Scanners --> Existing

Plugin ..> Pipeline : intercepts at\nauto-compaction
Plugin --> Sessions : writes checkpoint.<n>.json + plan.json
Plugin --> Knowledge : mergeAppend (append-only)
ClawAgent ..> Sessions : reads own sid only
ClawAgent ..> Knowledge : seeds discovery
ComposterAgent ..> Sessions : reads any sid (RO)
ComposterAgent ..> Knowledge : reads (RO)

Snew ..> Sessions
Snew ..> Knowledge
S1 ..> Existing
S2 ..> Existing

@enduml
