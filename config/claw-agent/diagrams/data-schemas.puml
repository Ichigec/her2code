@startuml claw-compactor-data-schemas
title Claw / Composter — data schemas
skinparam shadowing false
skinparam defaultFontName "JetBrains Mono"
skinparam classBackgroundColor #FFF7CC
skinparam classBorderColor #555
skinparam noteBackgroundColor #FFF7E5

class CompactionAction <<schema>> {
  id : string  (act_*)
  ts : date-time
  session_id : string
  op : merge|prune|collapse|rebudget|mcp-dedupe|rollback
  targets : string[1..*]
  rationale : string
  evidence : "path:line"[1..*]
  proposed_artifact : path?
  human_gate : pending|approved|rejected|applied
  model : string
  summary_ref : "summaries/YYYY-MM-DD.md#anchor"?
  registry_snapshot : path?
}

class IntegrationRecord <<schema>> {
  id : string
  source : path
  type : mcp|compose-service|skill|env|script|doc|llm-model|lsp|adapter|agent
  c_layer? : C0..C4
  linux_layer? : L0..L12
  endpoint? : url
  depends_on : string[]
  tools : { name, namespace?, schema_ref? }[]
  config_keys : string[]    (names only, secrets redacted)
  status? : configured|running|stale|unknown
  skill_id? : string|null
  discovered_at : date-time
  evidence : "path:line"[1..*]
}

class Checkpoint <<schema, new §12>> {
  session_id : string
  seq : int (>=1)
  ts : date-time
  tokens_before : int
  agent : claw|composter|other
  tools_found : ToolFound[]
  prospects : Prospect[]
  a2a_acp : A2AEndpoint[]
  plan_ref : "sessions/<sid>/plan.json"
  summary : string (<=500 chars)
}

class ContinuationPlan <<schema, new §12>> {
  session_id : string
  current_step : 1..6
  next_actions : string[1..*]
  blockers : string[]
  assumptions : string[]
  checkpoint_ref? : "sessions/<sid>/checkpoint.<n>.json"
}

class ToolCatalog <<schema, new §12>> {
  records : ToolCatalogRecord[]
}
class ToolCatalogRecord <<schema, new §12>> {
  id : string
  kind : mcp|lsp|script|compose-service|skill|agent|adapter|llm-model
  first_seen_session : string
  last_seen_session : string
  evidence : "path:line"[1..*]
  confirmations : int (>=1)
}

class ProspectIndex <<schema, new §12>> {
  records : ProspectRecord[]
}
class ProspectRecord <<schema, new §12>> {
  id : candidate.*
  candidate_path : "path:line"
  why_could_be_tool : string
  score : 0..1
  sessions_observed : string[1..*]
}

class A2AAcpIndex <<schema, new §12>> {
  records : A2ARecord[]
}
class A2ARecord <<schema, new §12>> {
  id : (a2a|acp|mcp).*
  transport : a2a|acp|mcp
  endpoint : string
  agent_card_url? : url
  capabilities : string[]
  first_seen_session? : string
  last_seen_session? : string
}

class ToolFound <<inline>> {
  id : string
  kind : ...
  source : "path:line"
  evidence : "path:line"[1..*]
}
class Prospect <<inline>> {
  id : candidate.*
  candidate_path : "path:line"
  why_could_be_tool : string
  score : 0..1
}
class A2AEndpoint <<inline>> {
  id : (a2a|acp|mcp).*
  transport : a2a|acp|mcp
  endpoint : string
  agent_card_url? : url
  capabilities : string[]
}

Checkpoint *-- "tools_found *" ToolFound
Checkpoint *-- "prospects *" Prospect
Checkpoint *-- "a2a_acp *" A2AEndpoint
ToolCatalog *-- "records *" ToolCatalogRecord
ProspectIndex *-- "records *" ProspectRecord
A2AAcpIndex *-- "records *" A2ARecord

note as N1
  HARD invariants (§7):
    - tools_found[].evidence : minItems 1
    - prospects[].score : 0..1
    - knowledge/* : append-only
end note

note right of Checkpoint
  Written by claw-compactor plugin
  on experimental.session.compacting.
  One file per checkpoint:
  sessions/<sid>/checkpoint.<n>.json
end note

note right of ContinuationPlan
  Rewritten on every checkpoint
  (unlike checkpoint.<n>.json which
  is append-only within a session).
end note

note bottom of ToolCatalog
  Append-only:
    new id -> push
    existing id -> last_seen_session += sid,
                   confirmations++,
                   evidence := union
end note

@enduml
