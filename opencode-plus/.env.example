# OpenCode+ local overrides (optional).
# Loaded after ../.env and ../.env.llamacpp by start-llama-qwen.sh and start-all.sh.
# Copy to opencode+/.env and adjust paths for your host.

# ── llama.cpp (host) ─────────────────────────────────────────────────────────
# LLAMA_CPP_DIR=${HOME}/dev/llama.cpp
# LLAMA_CPP_SERVER_BIN=${HOME}/dev/llama.cpp/build/bin/llama-server
# LLAMA_CPP_MODEL_PATH=${HOME}/.lmstudio/models/.../Qwen3.6-35B-A3B-heretic-bf16.gguf
# Gemma 26B: configs/profiles/llama-gemma-heretic.env + bash opencode+/start-llama-gemma.sh
# LLAMA_CPP_MMPROJ_PATH=${HOME}/.lmstudio/models/.../Qwen3.6-35B-A3B-heretic-mmproj-F32.gguf

# MTP speculative decoding (requires rebuild: bash opencode+/rebuild-llama-mtp.sh)
LLAMA_CPP_MTP_ENABLED=1
LLAMA_CPP_MTP_DRAFT_N_MAX=3

# No thinking; OpenCode/agent tools via Jinja (not llama-server --tools)
LLAMA_CPP_REASONING=off
LLAMA_CPP_CHAT_TEMPLATE_KWARGS={"enable_thinking":false}
LLAMA_CPP_JINJA=on

# LiteLLM routing: use host llama-server instead of LM Studio
# LLM_BACKEND=llamacpp

# ── Neo4j (claw tool graph; see compose.neo4j.yml) ─────────────────────────
# NEO4J_URI=bolt://127.0.0.1:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=changeme
# NEO4J_ENABLED=1

# ── OpenCode (optional overrides; defaults in ../.env.opencode) ─────────────
# OPENCODE_WEB_HOST_PORT=3400
# OPENCODE_DEFAULT_MODEL=litellm/qwen3.6-35b-heretic
