# LM Studio tvall + LiteLLM + OpenCode (llama.cpp выключен).
OPENCODE_PLUS_ACTIVE_PROFILE=lmstudio-tvall
OPENCODE_PLUS_CONFIG_TEMPLATE=${HOME}/cursor/first/opencode+/configs/opencode.litellm-dual.json
OPENCODE_USE_LITELLM=1
OPENCODE_LLM_PROVIDER=litellm
OPENCODE_LLM_BASE_URL=http://127.0.0.1:4000/v1
OPENCODE_LLM_API_KEY=sk-local
OPENCODE_DEFAULT_MODEL=litellm/tvall43-qwen3.6-35b-a3b-heretic
OPENCODE_SMALL_MODEL=litellm/qwen3.6-35b-heretic
OPENCODE_WORKSPACE_DIR=${HOME}/cursor/first
OPENCODE_STATE_DIR=${HOME}/.opencode-host
OPENCODE_WEB_HOST_PORT=3400
