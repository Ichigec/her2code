@startuml opencode-plus-logical
title <color:#FFFFFF>OpenCode+ — логическая схема (обвязка вокруг opencode)</color>
skinparam shadowing false
skinparam defaultFontName "JetBrains Mono"
skinparam defaultFontColor #000000
skinparam titleFontColor #FFFFFF
skinparam actorFontColor #FFFFFF
skinparam ArrowColor #444
skinparam component {
  FontColor #FFFFFF
  FontColor<<ui>> #FFFFFF
  FontColor<<plugin>> #FFFFFF
}
skinparam rectangle {
  FontColor<<core>>     #000000
  FontColor<<backend>>  #000000
  FontColor<<obs>>      #000000
  BackgroundColor<<ui>>        #EAF4FF
  BackgroundColor<<core>>      #FFF7CC
  BackgroundColor<<plugin>>    #FFE6CC
  BackgroundColor<<backend>>   #E8F7EC
  BackgroundColor<<orch>>      #F3E8FF
  BackgroundColor<<config>>    #F0F0F0
  BackgroundColor<<repo>>      #F5F5F5
  BackgroundColor<<obs>>       #E0F5FF
}

actor "<color:#FFFFFF>Разработчик\n(browser)</color>" as Dev

rectangle "OpenCode runtime (host, :3400)" <<core>> {
  component "opencode web\n:3400 (host CLI)" as WEB <<ui>>
  component "opencode core\nin-process\nагенты build/plan/general/\ndeep-explore/summary" as OC
  component "plugin: step-reviewer\nкаждые 10 шагов → verdict\nOK | CAUTION | STUCK" as PLUG <<plugin>>
}

rectangle "LLM backends" <<backend>> {
  component "LiteLLM container\n:4000 (compose.phoenix.yml)\nOpenAI-совместимый proxy" as LITE
  component "LM Studio\n:1234 (host GUI)\ntvall43-…heretic" as LMS
  component "llama-server\n:8092 (host, MTP)\nqwen3.6-35b-heretic" as LLAMA
}

rectangle "Наблюдаемость" <<obs>> {
  component "Phoenix\n(tracing / logs)" as PHX
}

Dev -[#FFFFFF]-> WEB : <color:#FFFFFF>HTTP / WS</color>

WEB --> OC
OC --> PLUG : события шагов/tools
OC --> LITE : <color:#FFFFFF>chat completions</color>
PLUG ..> LITE : <color:#FFFFFF>self-call (надсмотрщик)</color>

LITE --> LMS : alias tvall43-…
LITE --> LLAMA : alias qwen3.6-35b-heretic
LITE ..> PHX : <color:#FFFFFF>traces / logs</color>

@enduml
